{
  "entities": {
    "Trip": {
      "title": "Trip",
      "description": "A group trip being managed.",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "The name of the trip." },
        "destination": { "type": "string", "description": "The destination or meeting point." },
        "createdAt": { "type": "string", "format": "date-time", "description": "Creation timestamp." },
        "createdBy": { "type": "string", "description": "Username of the creator." },
        "creatorId": { "type": "string", "description": "Firebase Auth UID of the creator." },
        "admins": { "type": "array", "items": { "type": "string" }, "description": "List of co-admin UIDs." },
        "accessKey": { "type": "string", "description": "Secret key for joining as admin." }
      },
      "required": ["name", "createdAt", "creatorId"]
    },
    "User": {
      "title": "User",
      "description": "A participant in a trip.",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "Participant's name." },
        "phone": { "type": "string", "description": "Participant's phone number." },
        "email": { "type": "string", "format": "email", "description": "Participant's email address." },
        "status": { "type": "string", "enum": ["Not Boarded", "Boarded"], "description": "Boarding status." },
        "joinedAt": { "type": "string", "format": "date-time", "description": "Join timestamp." },
        "boardedAt": { "type": "string", "format": "date-time", "description": "Boarding timestamp." },
        "sos": {
          "type": "object",
          "properties": {
            "active": { "type": "boolean" },
            "location": {
              "type": "object",
              "properties": {
                "lat": { "type": "number" },
                "lng": { "type": "number" }
              }
            },
            "timestamp": { "type": "string", "format": "date-time" },
            "message": { "type": "string" }
          }
        }
      },
      "required": ["name", "status", "joinedAt"]
    }
  },
  "firestore": {
    "/trips/{tripId}": {
      "schema": "Trip",
      "description": "Main trip document."
    },
    "/trips/{tripId}/users/{userId}": {
      "schema": "User",
      "description": "Participants in the trip."
    }
  }
}
